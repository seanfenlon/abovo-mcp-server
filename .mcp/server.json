{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.seanfenlon/abovo-mcp-server",
  "title": "ABOVO.co — Email-to-Web Publishing",
  "description": "Publish content to the web by emailing POST@abovo.co. No API key, no signup. SMTP is the API.",
  "version": "1.0.0",
  "websiteUrl": "https://abovo.replit.app",
  "repository": {
    "url": "https://github.com/seanfenlon/abovo-mcp-server",
    "source": "github"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://abovo.replit.app/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@seanfenlon/abovo-mcp-server",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {"name": "ABOVO_SMTP_HOST", "description": "SMTP server hostname", "isRequired": false, "format": "string", "isSecret": false},
        {"name": "ABOVO_SMTP_PORT", "description": "SMTP port", "isRequired": false, "format": "string", "isSecret": false},
        {"name": "ABOVO_SMTP_USER", "description": "SMTP username/email", "isRequired": true, "format": "string", "isSecret": false},
        {"name": "ABOVO_SMTP_PASS", "description": "SMTP password or app password", "isRequired": true, "format": "string", "isSecret": true},
        {"name": "ABOVO_SENDER_EMAIL", "description": "Sender email address", "isRequired": false, "format": "string", "isSecret": false}
      ]
    }
  ]
}
